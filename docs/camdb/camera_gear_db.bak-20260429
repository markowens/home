function openEdit(id) {
  const item = gear.find(g => g.id === id);
  if (!item) return;
  editingId = id;

  document.getElementById('modal-cat-label').textContent = item.category;
  document.getElementById('modal-cat-label').className = 'modal-cat cat-badge ' + item.category;

  const fields = FIELD_DEFS[item.category] || [];
  const grid = document.getElementById('modal-fields');
  grid.innerHTML = fields.map(f => {
    const val = item[f.key] || '';
    if (f.type === 'select') {
      const opts = f.opts.map(o => `<option${o === val ? ' selected' : ''}>${o}</option>`).join('');
      return `<div class="field"><label>${f.label}</label><select id="mf-${f.key}"><option value="">— Select —</option>${opts}</select></div>`;
    }
    return `<div class="field"><label>${f.label}</label><input id="mf-${f.key}" type="${f.type}" value="${esc(val)}"></div>`;
  }).join('');

  document.getElementById('edit-modal').classList.add('open');
}

function closeEdit() {
  editingId = null;
  document.getElementById('edit-modal').classList.remove('open');
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById('edit-modal')) closeEdit();
}

function saveEdit() {
  const item = gear.find(g => g.id === editingId);
  if (!item) return;
  const fields = FIELD_DEFS[item.category] || [];
  fields.forEach(f => {
    const el = document.getElementById('mf-' + f.key);
    if (el) item[f.key] = el.value.trim();
  });
  save();
  renderTable();
  updateCounters();
  closeEdit();
  showToast('\u2713 Changes saved');
}

// ── Init ───────────────────────────────────────────────
renderTable();
updateCounters();
</script>

<div class="io-toast" id="io-toast"></div>
</body>
</html>
